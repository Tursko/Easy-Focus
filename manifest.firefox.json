{
    "manifest_version": 3,
    "version": "1.0",
    "name": "Easy Focus",
    "action" : {
        "default_popup": "popup.html"
    },
    "background": {
        "scripts": ["background.js"]
    },
    "permissions": [
        "storage",
        "tabs"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "easyfocus@tursko"
        }
    }
}
